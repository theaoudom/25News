# ---------------------------------------------------------------------------
# 26News environment variables
# Copy this file to ".env.local" and fill in real values for local dev.
# On Vercel, configure these in Project Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Public site URL (no trailing slash). Used for canonical URLs, sitemap, OG tags.
# Set this to your permanent custom domain once it is live.
NEXT_PUBLIC_SITE_URL=https://26news.xyz

# Google AdSense publisher id (already used by the existing site).
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-5602570319866246

# Google Analytics 4 measurement id (e.g. G-XXXXXXXXXX). Leave blank to disable.
NEXT_PUBLIC_GA_ID=

# Google Search Console verification token (the content="..." value from the
# "HTML tag" verification method). Leave blank to disable.
NEXT_PUBLIC_GSC_VERIFICATION=

# ---------------------------------------------------------------------------
# Football / World Cup data.
# The World Cup section works with NO configuration: it uses the free
# TheSportsDB public key, falls back to openfootball (no key), and finally to a
# bundled dataset. Provider chain: TheSportsDB -> openfootball -> fallback.
# ---------------------------------------------------------------------------

# TheSportsDB primary source. The public test key "3" works out of the box;
# register a free key at https://www.thesportsdb.com/ for higher rate limits.
THESPORTSDB_KEY=3

# TheSportsDB league id for the FIFA World Cup.
THESPORTSDB_WC_LEAGUE_ID=4429

# Tournament season year (shared by all providers).
FOOTBALL_WORLDCUP_SEASON=2026
