# ---------------------------------------------------------------------------
# 25News environment variables
# Copy this file to ".env.local" and fill in real values for local dev.
# On Vercel, configure these in Project Settings → Environment Variables.
# ---------------------------------------------------------------------------

# Public site URL (no trailing slash). Used for canonical URLs, sitemap, OG tags.
NEXT_PUBLIC_SITE_URL=https://25news.xyz

# Google AdSense publisher id (already used by the existing site).
NEXT_PUBLIC_ADSENSE_CLIENT=ca-pub-5602570319866246

# ---------------------------------------------------------------------------
# Football data provider (API-Football via RapidAPI or api-football.com).
# The site works WITHOUT these set — it falls back to bundled World Cup data.
# Free tier: https://www.api-football.com/  (or RapidAPI "API-Football").
# ---------------------------------------------------------------------------

# Your API-Football key. Leave blank to use the bundled fallback dataset.
FOOTBALL_API_KEY=

# Base host. Use "v3.football.api-sports.io" for direct api-football.com keys,
# or "api-football-v1.p.rapidapi.com" for RapidAPI keys.
FOOTBALL_API_HOST=v3.football.api-sports.io

# League id for the FIFA World Cup in API-Football is 1. Season is the year.
FOOTBALL_WORLDCUP_LEAGUE_ID=1
FOOTBALL_WORLDCUP_SEASON=2026
